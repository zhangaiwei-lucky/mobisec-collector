<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 警告横幅 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#B71C1C"
            android:padding="10dp"
            android:text="★ 创新亮点：以下所有传感器数据访问均无需任何权限！"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <!-- 传感器列表 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1565C0"
            android:paddingStart="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="设备传感器清单"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tv_sensor_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:textSize="11sp"/>

        <!-- 实时数据显示 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1565C0"
            android:paddingStart="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="实时传感器数据"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tv_realtime_accel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E3F2FD"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:text="加速度(m/s²): 点击开始采集"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tv_realtime_gyro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E8F5E9"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:text="角速度(rad/s): 点击开始采集"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>

        <!-- 采集控制 -->
        <Button
            android:id="@+id/btn_start_sample"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="开始5秒采集分析"
            android:backgroundTint="#1565C0"/>

        <ProgressBar
            android:id="@+id/progress_sampling"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"/>

        <!-- 活动识别结果 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1565C0"
            android:paddingStart="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="用户活动识别（无需权限）"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tv_activity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:fontFamily="monospace"
            android:padding="10dp"
            android:text="采集后显示活动状态分析..."
            android:textSize="13sp"/>

        <!-- 硬件指纹结果 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#B71C1C"
            android:paddingStart="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="传感器硬件指纹（可跨 Reset 追踪设备）"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tv_fingerprint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFEBEE"
            android:fontFamily="monospace"
            android:padding="10dp"
            android:text="采集后显示设备传感器指纹..."
            android:textSize="12sp"/>

    </LinearLayout>
</ScrollView>
